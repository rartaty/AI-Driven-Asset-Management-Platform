# ==========================================
# Project Big Tester - Environment Variables
# ==========================================
# 使い方: このファイルをコピーして「.env」という名前に変更し、
# 実際のパスワードやキーを入力してください。

# ------------------------------------------
# システム設定
# ------------------------------------------
# トレードモード (PAPER | PAPER_LIVE | REAL)
# Phase 8c (ADR-0012) で三値化:
#   PAPER     : yfinance 疑似 tick + paper_trader 仮想発注 (kabu Station 不要・初期検証用 / qty=100 固定)
#   PAPER_LIVE: kabu Push 実 tick + paper_trader 仮想発注 (kabu Station 必要・実マーケット検証 / position sizing)
#   REAL      : kabu Push 実 tick + kabucom.place_order 実発注 (CLAUDE.md 絶対禁止1: 切替時は明示確認必須)
# 注: 旧 TEST_MODE は Phase 5 で TRADE_MODE に統合 (deprecated)。
TRADE_MODE=PAPER

# Paper trader 初期仮想資金 (PAPER / PAPER_LIVE モードの架空資金)
PAPER_INITIAL_CAPITAL=1000000

# Position sizing (PAPER_LIVE / REAL モード共通)
# buying_power の何% を 1 取引あたりの基本サイズとするか (0.0 〜 1.0)
# 例: 0.20 = 20% / buying_power=¥1,000,000 のとき 1 取引基本 ¥200,000
POSITION_SIZE_PCT=0.20

# kabu 手数料無料枠 (1 日の総売買代金上限・自分のプランに合わせて設定)
# 1日定額コース: 1000000 (¥100万)
# 月額定額やキャンペーンによって変わる場合は実際の値を設定
# 0 を指定すると制限なし (PAPER モードでは無視される)
KABU_DAILY_ORDER_LIMIT_YEN=1000000

# REAL モード追加上限 (Phase 8d 用、デフォルト 0 = 制限なし)
# 100 株テスト等の段階移行で「1 取引あたり」を絞りたい場合に使用
# 例: 50000 (¥50K) で初期テスト → 0 で通常運用
# REAL_MAX_YEN_PER_TRADE=0

# REAL モード起動確認文字列 (CLAUDE.md 絶対禁止1: 起動時の明示確認)
# 環境変数を設定しないと runner/main_trade.py が REAL 起動を拒否
# RUNNER_REAL_CONFIRM=I_UNDERSTAND_REAL_TRADING_RISK

# ------------------------------------------
# 証券API設定 (auカブコム証券 kabusapi)
# ------------------------------------------
# kabuステーションが起動しているローカルマシンのURLとポート
KABUCOM_API_URL=http://localhost:8080/kabusapi
KABUCOM_API_PASSWORD=your_kabucom_password_here

# ------------------------------------------
# 銀行API設定 (OpenCanvas / AnserParasol)
# ------------------------------------------
# OIDC連携用のクライアント情報
BANK_API_CLIENT_ID=your_opencanvas_client_id_here
BANK_API_CLIENT_SECRET=your_opencanvas_client_secret_here
BANK_API_BASE_URL=https://api.opencanvas.ne.jp/anserparasol/v1

# ------------------------------------------
# Web 管理者認証 (要件 E.5.1 / WAF 監査 C3)
# ------------------------------------------
# FastAPI ルーターを保護する管理者トークン。
# 本番は AWS SSM (/projectbig/admin/api-token) に登録し load-secrets.ps1 が環境変数へ展開。
# 開発時の暫定としてここに設定可。
# 注意: 未設定だと API は全リクエストを 503 拒否する
#       (旧実装のハードコード既定値 "dev-token-secret" は廃止)。
ADMIN_API_TOKEN=your_admin_token_here
